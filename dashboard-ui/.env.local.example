# Backend API (FastAPI)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Dashboard auth (must match backend API_KEY)
NEXT_PUBLIC_API_KEY=dev-dashboard-key

# Optional tenant headers (defaults from backend .env)
NEXT_PUBLIC_BRAND_SLUG=orzen-demo
NEXT_PUBLIC_STORE_ID=store-001

# Polling interval for live stats (ms)
NEXT_PUBLIC_POLL_INTERVAL_MS=10000
