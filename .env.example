# --- Local dev without Docker (Windows): use SQLite ---
DATABASE_URL=sqlite:///./data/orzen_dev.db

# --- Production / Docker Compose: use PostgreSQL ---
# DATABASE_URL=postgresql+psycopg2://retail:retail@localhost:5432/retail_analytics

REDIS_URL=redis://localhost:6379/0

# InsightFace: -1 = CPU, 0 = GPU (CUDA)
INSIGHTFACE_CTX_ID=-1
# Edge posts metadata via API instead of direct DB (optional)
EDGE_USE_CLOUD_EVENTS=false
REQUIRE_TLS=false

# Multi-tenant
BRAND_SLUG=orzen-demo
STORE_ID=store-001
CAMERA_ID=cam-001

# Edge ↔ cloud
BACKEND_URL=http://localhost:8000
EDGE_API_KEY=
EDGE_DEVICE_NAME=jetson-01
HEARTBEAT_INTERVAL_SECONDS=30
PIPELINE_BACKEND=opencv

# Single camera fallback
RTSP_URL=0

# Multi-camera JSON (overrides RTSP_URL when set)
# CAMERAS_JSON=[{"camera_id":"cam-001","rtsp_url":"rtsp://user:pass@192.168.1.10/stream1"},{"camera_id":"cam-002","rtsp_url":"rtsp://user:pass@192.168.1.11/stream1"}]
MULTI_CAMERA_ENABLED=false
MAX_CAMERA_WORKERS=4

RECOGNITION_THRESHOLD=0.55
MIN_FACE_SCORE=0.6
MIN_BBOX_AREA=1600
VIP_VISIT_THRESHOLD=10
REPEAT_VISIT_WINDOW_HOURS=24

FRAME_SKIP=2
DET_SIZE=640
MAX_LIVE_VISITOR_SECONDS=30

# Dashboard auth — API key and/or JWT (must match dashboard-ui NEXT_PUBLIC_API_KEY)
API_KEY=dev-dashboard-key
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRE_MINUTES=1440

# Browser test: http://127.0.0.1:8000/api/live-visitors?api_key=dev-dashboard-key
